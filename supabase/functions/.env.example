# Master Key Encryption Key (KEK) for wrapping per-user entry DEKs.
# 32 random bytes, base64-encoded. Generate with:  openssl rand -base64 32
#
# Local dev:  copy this file to supabase/functions/.env and run
#             supabase functions serve --env-file supabase/functions/.env
# Production: supabase secrets set ENTRY_MASTER_KEK=<base64>
#
# CRITICAL: back this value up outside Supabase. If it is lost, every wrapped DEK — and
# therefore all encrypted entries — becomes permanently unrecoverable.
ENTRY_MASTER_KEK=

# ── send-notifications (web push) ─────────────────────────────────────────────
# VAPID keypair for the Web Push protocol. Generate with:  npx web-push generate-vapid-keys
# The PUBLIC key must also be exposed to the web app as NEXT_PUBLIC_VAPID_PUBLIC_KEY (same value).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@bloomjournal.app
#
# Shared bearer the pg_cron job sends to authorize the hourly run. Generate with:  openssl rand -base64 32
# Production: supabase secrets set NOTIFY_CRON_SECRET=<value>  AND store it in Vault as 'notify_cron_secret'
# (plus the function URL as 'notify_function_url') so the cron job can call the function.
NOTIFY_CRON_SECRET=
